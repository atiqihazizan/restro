function pahoMQTT(){
    var mqtt;
    var reconnectTimeout = 2000;
    var trycount = 0;
    var host = '167.99.79.49'; port = 1884;
    var path = '/mqtt';
    var topic = 'JTMIOT';
    var clientID = "web_" + parseInt(Math.random() * 100, 10)

//var msg  = '{"type":1,"serid":"203F530X002524","date":"20201014","time":"030343","lat":3.04925,"lon":101.69619,"alt":53,"gps":2,"sat":12,"hdop":0.69,"spd":27,"dir":233,"devid":8,"sts":0,"inp":0,"volt":0,"seq":221,"rid":0,"tid":0,"ts":1602673423}';
    var msg = '';

    // $('#host').val(host);
    // $('#port').val(port);
    // $('#message').val(msg);

    function MQTTconnect() {

        mqtt = new Paho.MQTT.Client(host,port,path,clientID);

        var options = {
            timeout: 3,
            useSSL: false,
            cleanSession: true,
            onSuccess: onConnect,
            onFailure: function (message) {
                trycount++;
                var logstr = "Connection failed: " + message.errorMessage + "Retrying("+trycount+")";
                console.log(logstr);
                setTimeout(MQTTconnect, reconnectTimeout);
            }
        };
        mqtt.onConnectionLost = onConnectionLost;
        mqtt.onMessageArrived = onMessageArrived;
        mqtt.connect(options);
    }

    function get_time()
    {
        var date = new Date();
        var hr = "0" + date.getHours();
        var mn = "0" + date.getMinutes();
        var sc = "0" + date.getSeconds();
        var tm = hr.substr(-2)+":"+mn.substr(-2)+":"+sc.substr(-2);
        return tm;
    }

    function onConnect() {
        console.log('Connected.');
        mqtt.subscribe(topic, {qos: 0});
        // $('#status').val('Connected.');
    }

    function onConnectionLost(response) {
        trycount++;
        var logstr = "connection lost: " + response.errorMessage + ". Reconnecting("+trycount+")";
        console.log(logstr);
        setTimeout(MQTTconnect, reconnectTimeout);
    }

    function onMessageArrived(message) {
        var mytopic = message.destinationName;
        var payload = message.payloadString;
        console.log(message)
        // $('#status').val(payload);
        // $('#content').append(payload+'<br>');
        //var data = JSON.parse(payload);
        //console.log(adata);
    }

    // $("#send").on("click", function(){
    //     if (!mqtt) {
    //         return;
    //     }
    //     var topic = $('#topic').val();
    //     var msg = $('#message').val();
    //     var message = new Paho.MQTT.Message(msg);
    //     message.destinationName = topic;
    //     mqtt.send(message);
    // });
    return {
        connect: MQTTconnect,
        send: function(msg){
            if(!mqtt) return;
            var message = new Paho.MQTT.Message(msg);
            message.destinationName = topic;
            mqtt.send(message);
        },
        get: function(){

        }
    }
}

function busyOn(frame){
    const loader1 = `<div class="loading-full">
  <div class="spinner-border loading-icon text-succes"></div>
  <span class="loading-text">Please wait...</span>
</div>`;
    const test2 = document.querySelector(frame);
    test2.insertAdjacentHTML('beforeend', loader1);
    const loadingFull = document.querySelector('.loading-full');
    const loading = new mdb.Loading(loadingFull, {scroll: false, backdropID: 'full-backdrop'})
}
function busyOff(){
    const backdrop = document.querySelector('#full-backdrop');
    const loadingFull = document.querySelector('.loading-full');
    backdrop.remove()
    loadingFull.remove()
    // document.body.style.overflow = ''
}
