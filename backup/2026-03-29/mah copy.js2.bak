function inputNumeric(input,def=''){input.value = input.value.replace(/[^0-9.]/g, def).replace(/(\..*)\./g, '$1');}
function inputCurrency(input,def=''){input.value = input.value.replace(/[^0-9.]/g, def).replace(/(\..*)\./g, '$1');}
function currency(str){return Number(str).toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');}
function pageChange(href,pages,tabs){
    // document.querySelector('#backdrop')
    let pageEL = document.querySelector(href);
    document.querySelectorAll(tabs + '.active').forEach(a=>{
        if(!a.classList.contains('active')) return;
        a.classList.remove('active');
    })
    if(pageEL){
        document.querySelectorAll(pages + '.active').forEach(f=>{
            if(!f.classList.contains('active')) return;
            f.classList.remove('active')
            f.classList.add('d-none')
        })
        pageEL.classList.add('active')
        pageEL.classList.remove('d-none')
    }
    return pageEL
}
function initTabs(tabs,pages,callback){
    document.querySelectorAll(tabs).forEach(function(cl){
        cl.addEventListener('click',function(e){
            e.preventDefault()
            const href = this.getAttribute('href');
            let pageEL;

            if(href === 'javascript:void(0)') return false;
            // pageEL.scrollIntoView()
            pageEL= pageChange(href,pages,tabs)
            this.classList.add('active')
            if(callback) callback(this,pageEL)
        })
    })
}
function print(title){
    let html = document.getElementById('printpage').innerHTML;
    printJS(html,title)
}
async function printJS(html, title) {
    //let html = divId.innerHTML;
    let ifra = document.getElementById('printJS');
    let tmpTitle = document.title
    document.title = title;
    // let mywindow = window.open('', 'PRINT', 'height=650,width=1900,top=100,left=150');

    if(ifra === null){
        ifra = document.createElement('iframe')
        ifra.id="printJS"
        ifra.setAttribute('style','position: absolute;width: 0;height: 0;border: 0; visibility: hidden;')
        window.document.body.appendChild(ifra)
    }
    ifra = ifra.contentWindow || ifra.contentDocument.document || ifra.contentDocument;
    ifra.document.write(`<html><head><title>${title}</title>`);

    // <link rel="stylesheet" href="{{ URL::asset('/css/plugin/compiled.min.css')}}" />
    // <link rel="stylesheet" href="{{ URL::asset('/css/plugin/mdb.min.css')}}" />

    ifra.document.write(`<link href="/css/plugin/compiled.min.css" rel="stylesheet" type="text/css" />`)
    ifra.document.write(`<link href="/css/plugin/mdb.min.css" rel="stylesheet" type="text/css" />`)
    ifra.document.write(`<link href="/css/ui-kit/mdb.min.css" rel="stylesheet" type="text/css" />`)
    /* Resit / laporan: gaya sama seperti di #receipt-container (URL relatif dari root laman) */
    ifra.document.write(`<link href="/css/print.css" rel="stylesheet" type="text/css" />`)
    ifra.document.write('</head><body onload="window.print();window.close()" style="background: #FFFFFF">');
    ifra.document.write(html);
    ifra.document.write('</body></html>');

    ifra.document.close(); // necessary for IE >= 10
    ifra.focus(); // necessary for IE >= 10*/
    document.title = tmpTitle;

    // mywindow.print();
    // mywindow.close();
    return true;
}
function showTime(){
    var date = new Date();
    var h = date.getHours(); // 0 - 23
    var m = date.getMinutes(); // 0 - 59
    var s = date.getSeconds(); // 0 - 59
    var session = "AM";

    if(h == 0){
        h = 12;
    }

    if(h > 12){
        h = h - 12;
        session = "PM";
    }

    h = (h < 10) ? "0" + h : h;
    m = (m < 10) ? "0" + m : m;
    s = (s < 10) ? "0" + s : s;

    var time = h + ":" + m + ":" + s + " " + session;
    // document.getElementById("MyClockDisplay").innerText = time;
    // document.getElementById("MyClockDisplay").textContent = time;
    console.log(time)
    // setTimeout(showTime, 1000);
}

