html,body { overflow: hidden; width: 100vw; height: 100vh;}
body { position: relative}
.gray-black {background-color: #26272c; color: #f5f5f5;}
.h-topbar { height: 70px !important;}
.page-frame {width: 100vw;  height: calc(100vh ); padding-top: 70px}
.nav-link-page.nav-counter {
    padding: 1.1rem 1rem;
    margin-right: 1.6rem;
    font-size: 1.25rem;
    font-weight : 500;
    color: whitesmoke;
}
.nav-link-page.nav-counter:hover, .nav-link-page.nav-counter.active {
    border-bottom: .4rem solid #0bf16b;
    padding-bottom: calc(1.1rem - .4rem);
    color: #0bf16b;
}

::-webkit-scrollbar {width: 5px; height: 5px}
::-webkit-scrollbar-track {background: transparent;}
::-webkit-scrollbar-thumb {background: dimgray;}
::-webkit-scrollbar-thumb:hover {background: dimgray;}

.fw-300 {font-weight: 300}
.fw-400 {font-weight: 400}
.fw-500 {font-weight: 500}
.fw-600 {font-weight: 600}

.sidebar {width: 230px;background: #26272c; color: #f5f5f5; height: calc(100vh - 70px);}
.sidenav { background-color: #26272c; color: #f5f5f5; }
.thead-tr {background-color: #26272c; color: #848792; font-weight: bold;}
.form-label { color: rgb(132 135 146) !important;}
.form-select {height: calc(1.6em + .75rem + 8px)}
.form-control,.form-select {
    background-color: #131218; color: #f5f5f5;
    border-radius: 3rem; border-color: #131218;
    line-height: 2.2;
}
.table { margin-bottom: 0}
.free-style {margin:0;padding:0;width:100%;background-color: transparent;border:0;color:white;}
.button-table-primary,.button-table-danger {
    width:30px; border:0;vertical-align: bottom;
    padding: 0.375rem 1rem 0.3125rem;
    font-size: .75rem;
    line-height: 1.5;
    border-radius: 0.5rem!important;
    --mdb-bg-opacity: 1;
    background-color: rgba(var(--mdb-black-rgb),var(--mdb-bg-opacity))!important;
    --mdb-text-opacity: 1;
    color: rgba(var(--mdb-primary-rgb),var(--mdb-text-opacity));
    display: inline-block;
    padding-right: 0.5rem!important;
    padding-left: 0.5rem!important;
}
.button-table-danger {
    --mdb-text-opacity: 1;
    color: rgba(var(--mdb-danger-rgb),var(--mdb-text-opacity));
}

/*** page dashboard ***/
.dashboard .dash-sidebar {
    display: flex;flex-direction: column;text-align: center;
}
.dashboard .dash-sidebar .dash-box {height: 100%}

/*** page POS ***/
.pos .pos-table-grid .card .card-body .card-title { text-align: center}
.pos .pos-table-grid {
    margin: 0 auto;
    width: 100%;
    display: grid;
    /*grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));*/
    /* grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); */
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    /* grid-auto-rows: auto; */
    grid-auto-rows: minmax(230px, auto);
    gap: 2rem;
    padding: 2rem;
    font-family: sans-serif;
    overflow-y: auto;
    /* height: calc(100vh - 70px); */
}
.pos .pos-table-grid .btn-add-order {box-sizing: border-box; }
.pos .pos-table-grid .btn-add-order { height: 210px }
.pos .pos-table-grid .card { height: 100% }
.pos .pos-table-grid .btn-rem-order { position : absolute; bottom: 1rem; left: 1.5rem}
.pos .pos-content-cate a.cate-link {
    background: #26272c;
    width: 128px;height: 105px;
    border-radius: 1.5rem;
    padding: 1rem 1.2rem;
    font-size: 1rem;
    color: #f5f5f5;
    justify-content: center;
    align-items: center;
    display: inline-flex;
    font-weight: 500;
}
.pos ::-webkit-scrollbar {height: 0;}
.pos .pos-content-cate a.cate-link.active {background-color: #009946;color: white; font-weight: bold;}
.pos .pos-content-cate{width: calc(100vw - 450px); overflow-x: auto;}
.pos-sidebar {
    width: 450px;
    display: flex;
    flex-direction: column;
    text-align: center;
    background: #26272c;
}
.pos-sidebar .empty { height: 100% }
.table-to-pay.table { margin: 0;}
.table-to-pay th,.table-to-pay td { padding:0 }
.table-to-pay tr th,.table-to-pay tr td { padding: .8rem; }
.table-to-pay tr th:first-child,.table-to-pay tr td:first-child { padding-left: 1rem}
.table-to-pay tr th:last-child,.table-to-pay tr td:last-child { padding-right: 1rem}
.table-to-pay.header th, .table-to-pay.footer .net th {padding-top: .8rem; padding-bottom: .8rem; background-color: #35363c;}
.table-to-pay.header th, .table-to-pay.footer .net th,.table-to-pay.footer .charge th {font-weight: 600;font-size: 1rem;}
.table-to-pay.body tbody td { border-bottom: 1px dashed rgb(245 237 237 / 30%); color: whitesmoke}
.table-to-pay.footer th { text-align: end; color: whitesmoke }
.table-to-pay.footer tfoot th:last-child { width:90px; }
.table-to-pay.footer tfoot .charge th { padding-top: 0; padding-bottom: .5rem }
.table-to-pay.footer tfoot .charge:first-child th { padding-top: 2.5rem; padding-bottom: .5rem }
.table-to-pay .item { width:auto; text-align: start}
.table-to-pay .price { width:60px; text-align: end}
.table-to-pay .qnt { width:40px; text-align: center}
.table-to-pay .total { width:90px; text-align: end}
.pos a.view-order { margin: 0;padding: 0; color: whitesmoke; cursor: pointer}
.pos a.view-order * { background-color: transparent}
.pos .button-pay .btn {
    margin: 0; display: block; width: 100%; border-radius: 0; box-shadow: none;
    font-size: 1.5rem; padding: 0.7rem 2rem;
}
#calculate .pos-calculate td {
    padding: 0;
    padding-right: 1rem;
    padding-bottom: 1rem;
}
#calculate .table-amount th,#calculate .table-amount td {
    font-weight: bold;
}
#calculate .pos-calculate button.btn-num {
    border: 0;
    border-radius: 2rem;
    text-align: center;
    padding: 1rem;
    box-sizing: border-box;
    height: 100%;
    width: 100%;
    font-size: 2rem;
    background-color: #2d5aa5;
    color: #fff;
    box-shadow: 0 4px 9px -4px #262626;
}
#calculate .table-amount .input-active {
    color: red !important;
    font-weight: 500;
}
#calculate .num-pad {width: 350px}
#calculate .amount-pay button{
    width: 100%;
    display: block;
    font-size: 1.5rem;
    margin-top: 1rem;
    border-radius: 2rem;
}
#calculate .amount-pay span{
    text-align: right;
    font-size: 4rem;
    border: 0;
    font-weight: 600;
    width: 100%;
    padding:0;
    height: 80px;
    margin-bottom: .8rem;
}
#calculate .amount-pay {
    width: 254px;
    margin-left : 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right : 1rem;
}

/*** page items ***/
.foods .foods-sidebar a { padding: 1rem 2rem }
.foods .foods-container {height: calc(100vh - 70px); padding: 0 60px 60px}
.foods .foods-title { padding: 30px 0; display: flex !important; justify-content: space-between!important;}
.foods .foods-content .table-foods thead tr {border-bottom: 2px solid green;}
.foods .foods-content .bg-odd,.foods .foods-content .bg-odd td select {background: #35363c;color: white;}
.foods .foods-content .bg-odd {font-weight: 400;}
.foods .foods-content .bg-event,.foods .foods-content .bg-event td select {background-color: #26272c; color: white;}
.foods .foods-content .bg-event {font-weight: 400;}
/*.foods .foods-content .table-foods td:first-child { padding-left: .1rem}*/
/*.foods .foods-content .table-foods td:last-child { padding-right: .1rem}*/
.foods .foods-content {overflow-y: auto;height: calc(100vh - 193px);}
.foods .food-nav {color:#f5f5f5;}
.foods .food-nav.active {border-left: .4rem solid #0bf16b;color: #0bf16b;padding-left: calc(2rem - .4rem);}
.foods table td button { width: 30px }
#item_form ,#cate_form  {background-color: transparent; color: #f5f5f5;}
#item_form ,#cate_form {width: 400px;}
#item_form button,#cate_form button{margin: 0}
#item_form form [name],#cate_form form [name]{border-radius: 2rem;}
#item_form .sidenav-food, #cate_form .sidenav-food {background-color: #26272c; color: #f5f5f5;}
#item_form .sidenav-food-container, #cate_form .sidenav-food-container{height: 100vh; padding: 2rem;}
/*#cate_form .cate-header_top, #item_form .item-header_top { height: 92.59px;}*/
#cate_form .cate-header_top, #item_form .item-header_top { height: 70.59px;}
#cate_form .cate-header, #item_form .item-header { height: 81.59px;}
#cate_form .cate-footer, #item_form .item-footer { height: 86.39px;}

/*** page sales ***/
/* Elak jadual lebar picit sidebar: flex child perlu min-width:0 supaya boleh susut */
.sales.d-flex {
	min-width: 0;
}
.sales .sidebar.sales-sidebar {
	flex-shrink: 0;
	flex-basis: 230px;
	width: 230px;
	max-width: 230px;
}
.sales .sales-content {overflow-y: auto;height: calc(100vh - 200px);}
.sales .sales-sidebar a { padding: 1rem 2rem }
.sales .sales-container {
	height: 100vh;
	padding: 0 60px 60px;
	min-width: 0;
	overflow: hidden;
}
.sales .sales-title { padding: 30px 0; display: flex !important; justify-content: space-between!important;}
.sales .sales-content .table-sales thead tr {border-bottom: 2px solid green;}
.sales .sales-content .bg-odd {background: #35363c;color: white;font-weight: 400;}
.sales .sales-content .bg-event {background-color: #26272c; color: white;font-weight: 400;}
/*.sales .sales-content .table-sales td:first-child { padding-left: .1rem}*/
/*.sales .sales-content .table-sales td:last-child { padding-right: .1rem}*/
.foods .foods-content {overflow-y: auto;height: calc(100vh - 193px);}
.sales .report-nav {color:#f5f5f5;}
.sales .report-nav.active {border-left: .4rem solid #0bf16b;color: #0bf16b;padding-left: calc(2rem - .4rem);}

/* Jadual laporan: baris data boleh scroll, jumlah kekal di bawah */
.sales .sales-content.sales-content-sticky-summary {
	display: flex;
	flex-direction: column;
	min-height: 0;
	min-width: 0;
	overflow: hidden;
}
.sales .sales-table-sticky {
	display: flex;
	flex-direction: column;
	flex: 1;
	min-height: 0;
	min-width: 0;
}
/* Kepala jadual di luar scroll — garis hijau pada thead (global .table-sales thead tr) */
.sales .sales-table-head-wrap {
	flex-shrink: 0;
}
.sales .table-sales-split-head,
.sales .table-sales-split-body {
	width: 100%;
	table-layout: fixed;
}
.sales .sales-table-scroll {
	flex: 1;
	min-height: 0;
	min-width: 0;
	overflow-y: auto;
	overflow-x: auto;
}
.sales .sales-summary-footer {
	flex-shrink: 0;
	background: #131218;
	border-top: 2px solid #009946;
	padding-top: 0.2rem;
	padding-bottom: 0.25rem;
    margin-top: 0.3rem;
}
.sales .sales-summary-footer .table-sales th,
.sales .sales-summary-footer .table-sales td {
	border: 0;
	vertical-align: middle;
	padding-top: 0.8rem;
	padding-bottom: 0.8rem;
}
.sales .sales-summary-footer .table-sales h4 {
	margin: 0;
	font-size: 1.2rem;
	font-weight: 500;
	line-height: 1.25;
}

#sale_receipt {background-color: transparent; color: #f5f5f5;}
#sale_receipt {width: 400px;}
#sale_receipt button{margin: 0}
#sale_receipt form [name]{border-radius: 2rem;}
#sale_receipt .sidenav-receipt {background-color: #26272c; color: #f5f5f5;}
#sale_receipt .sidenav-receipt-container {height: 100vh; padding: 2rem;}
#sale_receipt .sidenav-receipt-container * { color: black; }
/*#sale_receipt .receipt-header_top { height: 100px;}*/
#sale_receipt .receipt-header_top { height: 70px;}

.table-to-pay .item {
	line-height: 1.4;
	vertical-align: top;
}
.table-to-pay td {
	font-family: "Noto Sans SC", system-ui, -apple-system, "Segoe UI", "PingFang SC", "Hiragino Sans GB",
		"Hiragino Sans", "Microsoft YaHei", "Microsoft JhengHei", sans-serif;
}
#sale_receipt .receipt-header { height: 81.59px;}
#sale_receipt .receipt-footer { height: 86.39px;}
