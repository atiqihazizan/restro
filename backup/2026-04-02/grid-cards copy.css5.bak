/**
 * grid-cards.css — grid kad seragam: senarai meja (POS) & senarai menu (ordering).
 *
 * Dimuat melalui @import dari:
 *   - counter.css → halaman kaunter staf (POS, jualan, item, dapur, papan pemuka)
 *   - style.css   → halaman ordering pelanggan (pilih meja, menu)
 *
 * Grep: data-table-list, data-menu-list, menu-list-grid, --grid-card-row
 *
 * Ubah saiz sel grid: --grid-card-min (lebar min lajur), --grid-card-row (tinggi baris tetap).
 * Fon menu ordering sahaja: laraskan --menu-card-title-size & --menu-card-price-size di bawah.
 * Fokus meja POS: --pos-table-focus-ring & --pos-table-focus-glow (warna cerah, jelas pada hijau/merah).
 *
 * --card-grid-canvas: latar grid meja (bukan hitam tulen #000) supaya box-shadow gelap pada kad kelihatan.
 */
:root {
	--grid-card-min: 230px;
	--grid-card-row: 230px;
	--grid-card-gap: 2rem;
	--grid-card-pad: 2rem;
	--card-grid-canvas: #1c1c22;
	/* Kad meja POS — rujukan iOS squircle + aktif #4CAF50 */
	--pos-table-squircle: clamp(16px, 5.5vw, 20px);
	--pos-table-active-ring: #4caf50;
	--pos-table-shadow-down: 0 4px 8px rgba(0, 0, 0, 0.42);
	--pos-table-shadow-down-hover: 0 6px 12px rgba(0, 0, 0, 0.48);
	--pos-table-focus-ring: #ffeb3b;
	--pos-table-focus-glow: rgba(255, 235, 59, 0.95);
	/* Tipografi kad menu (ordering) — naikkan nilai rem / vw jika mahu lebih besar */
	--menu-card-title-size: clamp(1.55rem, 3.2vw, 2.15rem);
	--menu-card-price-size: clamp(1.3rem, 2.6vw, 1.7rem);
}

.pos [data-table-list] {
	background-color: var(--card-grid-canvas);
}

.pos [data-table-list],
#menu-container .foods.menu-list-grid[data-menu-list] {
	margin: 0 auto;
	width: 100%;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(var(--grid-card-min), 1fr));
	grid-auto-rows: var(--grid-card-row);
	gap: var(--grid-card-gap);
	padding: var(--grid-card-pad);
	font-family: sans-serif;
	overflow-y: auto;
	align-content: start;
	box-sizing: border-box;
}

#menu-container .foods.menu-list-grid[data-menu-list] {
	height: calc(100vh - 70px);
}

.pos [data-table-list] {
	min-height: 0;
}

.pos [data-table-list] .card .card-body .card-title,
#menu-container .foods.menu-list-grid[data-menu-list] .card .card-body .card-title {
	text-align: center;
}

/* ========== POS: kad meja (squircle, tiada outline biasa, hijau + glow hanya .active) ========== */

.pos [data-table-list] a.view-order.pos-table-tile {
	display: block;
	height: 100%;
	min-height: 0;
	border-radius: var(--pos-table-squircle);
}

.pos [data-table-list] a.view-order.pos-table-tile:focus {
	outline: none;
}

.pos [data-table-list] a.view-order.pos-table-tile:focus-visible {
	outline: 2px solid var(--pos-table-active-ring);
	outline-offset: 3px;
	border-radius: calc(var(--pos-table-squircle) + 2px);
}

.pos [data-table-list] .pos-table-card {
	height: 100%;
	min-height: 0;
	box-sizing: border-box;
	border: none !important;
	border-radius: var(--pos-table-squircle) !important;
	outline: none !important;
	box-shadow: var(--pos-table-shadow-down);
	transition: box-shadow 0.2s ease, transform 0.2s ease;
}

/* Tiada garis sempadan pada keadaan biasa — hanya gradient + bayang bawah */
.pos [data-table-list] .pos-table-card--s0 {
	background: linear-gradient(180deg, #4a4a4a 0%, #2a2a2a 55%, #222 100%) !important;
}

.pos [data-table-list] .pos-table-card--s1 {
	background: linear-gradient(180deg, #3d6b4f 0%, #1e4a32 55%, #163524 100%) !important;
}

.pos [data-table-list] .pos-table-card--s2,
.pos [data-table-list] .pos-table-card--s3,
.pos [data-table-list] .pos-table-card--s4 {
	background: linear-gradient(180deg, #7a4545 0%, #4a2828 55%, #351c1c 100%) !important;
}

.pos [data-table-list] .pos-table-card-body {
	min-height: 0;
	overflow: hidden;
	background: transparent !important;
}

.pos [data-table-list] .pos-table-card-title {
	font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.pos [data-table-list] .pos-table-line {
	display: block;
	line-height: 1.15;
}

.pos [data-table-list] .pos-table-line--label {
	font-size: clamp(1.1rem, 2.8vw, 1.5rem);
	font-weight: 600;
}

.pos [data-table-list] .pos-table-line--num {
	font-size: clamp(1.65rem, 4.5vw, 2.6rem);
	font-weight: 700;
	margin-top: 0.35rem;
}

.pos [data-table-list] .pos-table-line--single {
	font-size: clamp(1.35rem, 3.5vw, 2rem);
	font-weight: 700;
}

/* Hover (bukan aktif): angkat sedikit, bayang bawah lebih kuat — tanpa ring */
.pos [data-table-list] a.view-order.pos-table-tile:not(.active):hover .pos-table-card {
	transform: translateY(-2px);
	box-shadow: var(--pos-table-shadow-down-hover);
}

.pos [data-table-list] a.view-order.pos-table-tile.active:hover .pos-table-card {
	transform: translateY(-1px);
}

/* Aktif / dipilih: ring hijau #4CAF50 + glow teks kuning/putih */
.pos [data-table-list] a.view-order.pos-table-tile.active .pos-table-card {
	transform: translateY(-1px);
	box-shadow:
		var(--pos-table-shadow-down),
		0 0 0 2px var(--pos-table-active-ring);
}

.pos [data-table-list] a.view-order.pos-table-tile.active .pos-table-card-title,
.pos [data-table-list] a.view-order.pos-table-tile.active .pos-table-line {
	color: #fffef8;
	text-shadow:
		0 0 4px rgba(255, 255, 220, 0.95),
		0 0 12px rgba(255, 230, 120, 0.85),
		0 0 20px rgba(255, 200, 80, 0.45),
		0 1px 2px rgba(0, 0, 0, 0.55);
}

/* Grid menu ordering (bukan POS): kekalkan */
#menu-container .foods.menu-list-grid[data-menu-list] .card {
	height: 100%;
	min-height: 0;
	box-sizing: border-box;
}

.pos [data-table-list] .btn-add-order {
	box-sizing: border-box;
	height: 100%;
	min-height: 0;
}

.pos [data-table-list] .btn-rem-order {
	position: absolute;
	bottom: 1rem;
	left: 1.5rem;
}

#menu-container .foods.menu-list-grid[data-menu-list] .btn-add-order,
#menu-container .foods.menu-list-grid[data-menu-list] .card {
	height: 100%;
	width: 100%;
	min-height: 0;
	box-sizing: border-box;
}

#menu-container .foods.menu-list-grid[data-menu-list] a.btn {
	margin: 0;
	width: 100%;
	height: 100%;
	display: block;
	min-height: 0;
	position: relative;
}

#menu-container .foods.menu-list-grid[data-menu-list] .btn-rem-order {
	position: absolute;
	bottom: 1rem;
	left: 1.5rem;
}

#menu-container .foods.menu-list-grid[data-menu-list] .card .card-body {
	min-height: 0;
	overflow: hidden;
}

#menu-container .foods.menu-list-grid[data-menu-list] .card .card-body .card-title {
	font-size: var(--menu-card-title-size);
	line-height: 1.2;
	font-weight: 700;
}

#menu-container .foods.menu-list-grid[data-menu-list] .card .card-body .card-text {
	font-size: var(--menu-card-price-size);
	line-height: 1.3;
	font-weight: 600;
}
