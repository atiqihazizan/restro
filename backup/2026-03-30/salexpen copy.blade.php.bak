@push('javascript')
<script>
	const tax = '{{ $comp->sst }}' * 1.0
	function ledgerNum(v) {
		if (v == null || v === '') return 0
		const n = Number(String(v).replace(/,/g, ''))
		return Number.isFinite(n) ? n : 0
	}
	function ledgerGrand(man, sumDet, taxVal) {
		if (man && man.total != null && man.total !== '') return ledgerNum(man.total)
		if (man && man.grandtotal != null && man.grandtotal !== '') return ledgerNum(man.grandtotal)
		return sumDet + ledgerNum(taxVal)
	}
	/** Selaraskan dengan lajur label (Category+Qty) vs satu lajur nilai; ubah jika struktur jadual bertambah */
	const SALES_REPORT_FOOTER_LABEL_COLSPAN = 2
	/** HTML footer Subtotal / Tax / Discount / Grand Total — standard untuk Daily, Monthly, Yearly */
	function salesReportSummaryFooterHtml(man) {
		const cs = SALES_REPORT_FOOTER_LABEL_COLSPAN
		const netTotal = ledgerNum(man.subtotal) + ledgerNum(man.tax)
		const discountAmt = ledgerNum(man.discount)
		const discountRow = discountAmt > 0 ? `
                    <tr>
                      <th colspan="${cs}" class="text-start"><h4 class="mb-0">Discount</h4></th>
                      <th class="text-end"><h4 class="mb-0">-${currency(discountAmt)}</h4></th>
                    </tr>` : ''
		return `
                <table class="table table-borderless table-sales mb-0">
                  <tbody>
                    <tr>
                      <th colspan="${cs}" class="text-start"><h4 class="mb-0">Subtotal</h4></th>
                      <th class="text-end"><h4 class="mb-0">${currency(ledgerNum(man.subtotal))}</h4></th>
                    </tr>
                    <tr>
                      <th colspan="${cs}" class="text-start"><h4 class="mb-0">Tax Amount</h4></th>
                      <th class="text-end"><h4 class="mb-0">${currency(ledgerNum(man.tax))}</h4></th>
                    </tr>
                    <tr>
                      <th colspan="${cs}" class="text-start"><h4 class="mb-0">Total</h4></th>
                      <th class="text-end"><h4 class="mb-0">${currency(netTotal)}</h4></th>
                    </tr>
                    ${discountRow}
                    <tr>
                      <th colspan="${cs}" class="text-start"><h4 class="mb-0">Grand Total</h4></th>
                      <th class="text-end"><h4 class="mb-0">${currency(ledgerNum(man.total))}</h4></th>
                    </tr>
                  </tbody>
                </table>`
	}
	/** Satu baris kategori + qty + amount — standard untuk Daily, Monthly, Yearly */
	function salesReportCategoryRowHtml(trClass, s) {
		return `<tr class="${trClass}">
                            <td class="text-start">${s.cate}</td>
                            <td class="text-center">${s.qnt}</td>
                            <td class="text-end">${currency(s.amount)}</td>
                        </tr>`
	}
	var mdb_salexpen = function() {
		const pageSale = document.getElementById('salexpen')
		const modalPrintEl = document.getElementById('sale_receipt')
		const modalPrint = mdb.Sidenav.getInstance(modalPrintEl);
		const dataSale = {}
		const dataRcpt = {}

		async function receiptPaid(data) {
			let el = modalPrintEl.querySelector('.receipt-sale-frame div[sales-receipt]')
			let reportEl = modalPrintEl.querySelector('.receipt-sale-frame div[report-receipt]')
			let item = data.item
			let toHide = el.querySelectorAll('.to-hide');
			el.querySelector('.receipt-sale-item tbody').innerHTML = item.map((r, n) => {
				return `<tr>
                        <td class="itm" style="text-align:top;font-size:11pt; width: 50%; text-align: left;">${r.name}</td>
                        <td class="qnt" style="text-align:top; font-size:11pt; width: 15px">${r.qty}</td>
                        <td class="prc" style="text-align:top; font-size:11pt; width: 100px;text-align: right">${currency(r.price)}</td>
                        <td class="amt" style="text-align:top; font-size:11pt; width: 130px; text-align: right">${currency(r.amount)}</td>
                    </tr>`
			}).join('')

			reportEl.style.display = 'none'
			el.style.display = 'block'
			el.querySelector('.paid_at').innerHTML = data.paid_at
			el.querySelector('.table_no').innerHTML = data.desk.name
			el.querySelector('.receipt_no').innerHTML = 'Inv #:' + data.rcptno
			el.querySelector('.subtotal').innerHTML = data.subtotal

			toHide.forEach(e => e.classList.add('d-none'));
			if (data.subtotal) toHide.forEach(e => (e.classList.contains('d-none')) && (e.classList.remove('d-none')));
			
			let netTotal = (data.subtotal * 1) + (data.rest * 1);
			if (data.rest) el.querySelector('.tax').innerHTML = currency(data.rest)
			el.querySelector('.total').innerHTML = currency(netTotal)
			
			if (data.discamt && data.discamt > 0) {
				el.querySelector('.discount').innerHTML = '-' + currency(data.discamt)
				el.querySelector('.discount-row').style.display = ''
			} else {
				el.querySelector('.discount-row').style.display = 'none'
			}
			
			if (data.grandtotal) el.querySelector('.grand').innerHTML = currency(data.grandtotal)
			if (data.paid) el.querySelector('.paid').innerHTML = currency(data.paid)
			if (data.change) el.querySelector('.bal').innerHTML = currency(data.change)
		}
		async function initSales() {
			let find = pageSale.querySelector('#viewdailysale').value;
			let res = await axios(APP_URL + 'counter/sales/?find=' + find)
			let data = res.data ?? []
			let tbody = pageSale.querySelector('#sales_list_data');
			tbody.innerHTML = data.map((s, n) => {
				let trClass = 'bg-odd';
				if ((n % 2) > 0) trClass = 'bg-event'
				dataSale[s.id] = s;
				dataSale[s.id].paid_at = moment(s).format('DD MMM YYYY hh:mm A');
				return `<tr class="${trClass}">
                            <td class="text-center">${s.rcptno}</td>
                            <td class="text-end">${ currency(s.grandtotal)}</td>
                            <td class="text-center">${s.order_cnt}</td>
                            <td class="text-center">${s.desk.code}</td>
                            <td class="text-center">
                                <button class="btn bg-black btn-sm px-2 rounded-5 text-success" data-view-receipt idx="${s.id}"><i class="fa fa-print"></i></button>
                            </td>
                        </tr>`
			}).join('')

			tbody.querySelectorAll('[data-view-receipt]').forEach(p => {
				p.addEventListener('click', function(e) {
					e.preventDefault()
					let id = this.getAttribute('idx')
					let data = dataSale[id]
					receiptPaid(data).then(() => modalPrintEl.querySelector('[data-printout]').click())
				})
			})
		}
		async function initDaily() {
			let find = pageSale.querySelector('#viewdaily').value;
			let res = await axios(APP_URL + 'counter/daily/?find=' + find)
			let data = res.data ?? []
			let tbody = pageSale.querySelector('#sales_daily_data');
			let footer = pageSale.querySelector('#sales_daily_footer');
			let man = data.man && data.man !== false ? data.man : {};
			let det = data.det ?? [];
			dataRcpt.data = det
			dataRcpt.man = man
			dataRcpt.date = moment(find).format('DD MMM YYYY')
			tbody.innerHTML = det.map((s, n) => {
				let trClass = 'bg-odd';
				if ((n % 2) > 0) trClass = 'bg-event'
				return salesReportCategoryRowHtml(trClass, s)
			}).join('')
			footer.innerHTML = salesReportSummaryFooterHtml(man)
		}
		async function initMonthly() {
			let find = pageSale.querySelector('#viewmonthly').value;
			let res = await axios(APP_URL + 'counter/monthly/?find=' + find)
			let data = res.data ?? []
			let tbody = pageSale.querySelector('#sales_monthly_data');
			let footer = pageSale.querySelector('#sales_monthly_footer');
			let man = data.man && data.man !== false ? data.man : {};
			let det = data.det ?? [];
			dataRcpt.data = det
			dataRcpt.man = man
			dataRcpt.date = moment(find).format('MMMM YYYY')
			tbody.innerHTML = det.map((s, n) => {
				let trClass = 'bg-odd';
				if ((n % 2) > 0) trClass = 'bg-event'
				return salesReportCategoryRowHtml(trClass, s)
			}).join('')
			footer.innerHTML = salesReportSummaryFooterHtml(man)
		}
		async function initYearly() {
			let find = pageSale.querySelector('#viewyearly').value;
			let res = await axios(APP_URL + 'counter/yearly/?find=' + find)
			let data = res.data ?? []
			let tbody = pageSale.querySelector('#sales_yearly_data');
			let footer = pageSale.querySelector('#sales_yearly_footer');
			let man = data.man && data.man !== false ? data.man : {};
			let det = data.det ?? [];
			dataRcpt.data = det
			dataRcpt.man = man
			dataRcpt.date = find
			tbody.innerHTML = det.map((s, n) => {
				let trClass = 'bg-odd';
				if ((n % 2) > 0) trClass = 'bg-event'
				return salesReportCategoryRowHtml(trClass, s)
			}).join('')
			footer.innerHTML = salesReportSummaryFooterHtml(man)
		}

		function reportPreview() {
			let receiptSale = modalPrintEl.querySelector('.receipt-sale-frame div[sales-receipt]')
			let reportEl = modalPrintEl.querySelector('.receipt-sale-frame div[report-receipt]')
			let data = dataRcpt
			let item = dataRcpt.data
			if (item.length == 0) return;
			let man = data.man && data.man !== false ? data.man : {}

			reportEl.style.display = 'block'
			receiptSale.style.display = 'none'
			reportEl.querySelector('.receipt-sale-item tbody').innerHTML = item.map((r, n) => {
				return `<tr>
                        <td class="itm" style="font-size:9pt;text-align:left">${r.cate}(${r.qnt})</td>
                        <td class="prc" style="font-size:9pt;text-align:right">${currency(r.amount)}</td>
                    </tr>`
			}).join('')
			reportEl.querySelector('.date_at').innerHTML = 'Report at : ' + data.date
			let netTotal = ledgerNum(man.subtotal) + ledgerNum(man.tax)
			reportEl.querySelector('.subtotal').innerHTML = currency(ledgerNum(man.subtotal))
			reportEl.querySelector('.tax').innerHTML = currency(ledgerNum(man.tax))
			reportEl.querySelector('.total').innerHTML = currency(netTotal);
			
			let discountAmt = ledgerNum(man.discount)
			if (discountAmt > 0) {
				reportEl.querySelector('.discount').innerHTML = '-' + currency(discountAmt)
				reportEl.querySelector('.discount-row-report').style.display = ''
			} else {
				reportEl.querySelector('.discount-row-report').style.display = 'none'
			}
			
			reportEl.querySelector('.grand').innerHTML = currency(ledgerNum(man.total));
			modalPrintEl.querySelector('[data-printout]').click();
		}

		function initPrintPreview() {
			pageSale.querySelector('[data-print-daily]').addEventListener('click', function(e) {
				e.preventDefault()
				reportPreview()
			})
			pageSale.querySelector('[data-print-monthly]').addEventListener('click', function(e) {
				e.preventDefault()
				reportPreview()
			})
			pageSale.querySelector('[data-print-yearly]').addEventListener('click', function(e) {
				e.preventDefault()
				reportPreview()
			})
			modalPrintEl.querySelector('[data-printout]').addEventListener('click', function(e) {
				let html = modalPrintEl.querySelector('#receipt-container').innerHTML
				e.preventDefault()
				printJS(html, 'Receipt Sales')
				modalPrint.hide();
			})
		}
		return {
			init: function() {
				initTabs('.report-nav', '.report-page', function(e) {
					let funName = e.getAttribute('data-fun-name')
					if (funName === 'initSales') initSales()
					if (funName === 'initDaily') initDaily()
					if (funName === 'initMonthly') initMonthly()
					if (funName === 'initYearly') initYearly()
				})
				pageSale.querySelector('#viewdailysale').addEventListener('change', initSales)
				pageSale.querySelector('#viewdaily').addEventListener('change', initDaily)
				pageSale.querySelector('#viewmonthly').addEventListener('change', initMonthly)
				pageSale.querySelector('#viewyearly').addEventListener('change', initYearly)
				initPrintPreview()
			},
			receipt: receiptPaid,
			sales: async function(data) {
				receiptPaid(data).then(() => {
					let html = modalPrintEl.querySelector('#receipt-container').innerHTML
					printJS(html, 'Receipt Sales')
				})
			},
		}
	}()
	mdb_salexpen.init();
</script>
@endpush