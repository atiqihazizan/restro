{
	"name": "restro",
	"version": "1.0.0",
	"description": "Restro desktop shell (Electron)",
	"author": "Restro",
	"main": "electron/main.cjs",
	"private": true,
	"scripts": {
			"dev": "vite",
			"build": "vite build",
			"electron": "electron .",
			"electron:prepare": "node scripts/prepare-electron-laravel.mjs",
			"electron:build:win64": "node scripts/prepare-electron-laravel.mjs && electron-builder --win --x64",
			"electron:build:win32": "node scripts/prepare-electron-laravel.mjs && electron-builder --win --ia32",
			"electron:build:win7": "node scripts/prepare-electron-laravel.mjs && electron-builder --win --x64 --ia32"
	},
	"devDependencies": {
			"axios": "^1.1.2",
			"electron": "22.3.27",
			"electron-builder": "24.13.3",
			"laravel-vite-plugin": "^0.7.2",
			"vite": "^4.0.0"
	},
	"build": {
			"appId": "com.restro.desktop",
			"productName": "Restro",
			"files": [
					"electron/**/*",
					"package.json"
			],
			"extraResources": [
					{
							"from": "bundled/laravel",
							"to": "laravel"
					}
			],
			"directories": {
					"output": "dist-electron"
			},
			"win": {
					"executableName": "Restro",
					"requestedExecutionLevel": "asInvoker",
					"target": [
							{
									"target": "portable",
									"arch": [
											"x64",
											"ia32"
									]
							},
							{
									"target": "dir",
									"arch": [
											"x64",
											"ia32"
									]
							}
					]
			}
	}
}
